{
  "name": "@takos/yurucommu",
  "version": "1.0.0",
  "exports": {
    ".": "./src/backend/public.ts",
    "./server": "./src/backend/public.ts",
    "./web": "./web/public.ts",
    "./web/styles.css": "./web/styles.css",
    "./plugins": "./src/plugin/public.ts"
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.971.0",
    "@ffmpeg/ffmpeg": "npm:@ffmpeg/ffmpeg@^0.12.15",
    "@ffmpeg/util": "npm:@ffmpeg/util@^0.12.2",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "hono": "npm:hono@^4.11.4",
    "html5-qrcode": "npm:html5-qrcode@^2.3.8",
    "jotai": "npm:jotai@^2.18.1",
    "qrcode.react": "npm:qrcode.react@^4.2.0",
    "react": "npm:react@^18.3.0",
    "react-dom": "npm:react-dom@^18.3.0",
    "react-router-dom": "npm:react-router-dom@^7.12.0",
    "vite": "npm:vite@^6.4.1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.3.0",
    "tailwindcss": "npm:tailwindcss@^4.1.18",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
    "wrangler": "npm:wrangler@^4.61.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "esbuild": "npm:esbuild@^0.25.12"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["deno.window", "dom", "dom.iterable"]
  },
  "tasks": {
    "dev": "deno run -A npm:wrangler dev",
    "dev:web": "deno run -A npm:vite --config web/vite.config.ts",
    "dev:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server.ts",
    "build": "deno run -A npm:vite build --config web/vite.config.ts",
    "build:worker": "deno run -A npm:esbuild src/backend/index.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser --target=es2022 --conditions=workerd,worker,browser --external:cloudflare:* --external:node:*",
    "deploy": "deno task build && deno run -A npm:wrangler deploy",
    "test": "deno test --allow-all src/ web/src/ test/",
    "lint": "deno lint src/ web/src/",
    "fmt": "deno fmt src/ web/src/",
    "fmt:check": "deno fmt --check src/ web/src/",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:push": "deno run -A npm:drizzle-kit push",
    "db:migrate": "deno run -A npm:drizzle-kit migrate",
    "db:studio": "deno run -A npm:drizzle-kit studio"
  }
}
