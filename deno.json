{
  "name": "@takos/yurucommu",
  "version": "1.0.0",
  "exports": {
    ".": "./src/backend/public.ts",
    "./server": "./src/backend/public.ts",
    "./web": "./web/public.ts",
    "./web/styles.css": "./web/styles.css",
    "./plugins": "./src/plugin/public.ts"
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.971.0",
    "@babel/core": "npm:@babel/core@^7.29.0",
    "@cloudflare/workers-types": "npm:@cloudflare/workers-types@^4.20260420.1",
    "@ffmpeg/ffmpeg": "npm:@ffmpeg/ffmpeg@^0.12.15",
    "@ffmpeg/util": "npm:@ffmpeg/util@^0.12.2",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "better-sqlite3": "npm:better-sqlite3@^12.4.1",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "hono": "npm:hono@^4.11.4",
    "html5-qrcode": "npm:html5-qrcode@^2.3.8",
    "jotai": "npm:jotai@^2.18.0",
    "solid-jotai": "npm:solid-jotai@^0.3.0",
    "solid-js": "npm:solid-js@^1.9.0",
    "solid-refresh/babel": "npm:solid-refresh@^0.6.3/babel",
    "@solidjs/router": "npm:@solidjs/router@^0.15.0",
    "@tailwindcss/node": "npm:@tailwindcss/node@^4.1.18",
    "@tailwindcss/node/require-cache": "npm:@tailwindcss/node@^4.1.18/require-cache",
    "@tailwindcss/oxide": "npm:@tailwindcss/oxide@^4.1.18",
    "qrcode.react": "npm:qrcode.react@^4.2.0",
    "vite": "npm:vite@^6.4.1",
    "vitefu": "npm:vitefu@^1.1.3",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.0",
    "tailwindcss": "npm:tailwindcss@^4.1.18",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
    "assert": "node:assert",
    "babel-preset-solid": "npm:babel-preset-solid@^1.9.12",
    "buffer": "node:buffer",
    "child_process": "node:child_process",
    "crypto": "node:crypto",
    "events": "node:events",
    "fdir": "npm:fdir@^6.5.0",
    "fs": "node:fs",
    "fs/promises": "node:fs/promises",
    "http": "node:http",
    "https": "node:https",
    "merge-anything": "npm:merge-anything@^5.1.7",
    "module": "node:module",
    "net": "node:net",
    "os": "node:os",
    "path": "node:path",
    "picomatch": "npm:picomatch@^4.0.4",
    "rollup/parseAst": "npm:rollup@^4.60.2/parseAst",
    "stream": "node:stream",
    "tinyglobby": "npm:tinyglobby@^0.2.16",
    "tls": "node:tls",
    "tty": "node:tty",
    "url": "node:url",
    "util": "node:util",
    "vite/module-runner": "npm:vite@^6.4.1/module-runner",
    "worker_threads": "node:worker_threads",
    "zlib": "node:zlib",
    "wrangler": "npm:wrangler@^4.61.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "esbuild": "npm:esbuild@^0.25.12"
  },
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["deno.window", "dom", "dom.iterable"],
    "types": ["@cloudflare/workers-types"]
  },
  "lint": {
    "rules": {
      "exclude": [
        "jsx-button-has-type",
        "jsx-boolean-value",
        "jsx-curly-braces",
        "no-explicit-any",
        "no-import-prefix",
        "no-slow-types",
        "no-unused-vars",
        "no-unversioned-import",
        "no-node-globals",
        "no-window-prefix",
        "no-window",
        "require-await",
        "verbatim-module-syntax"
      ]
    }
  },
  "tasks": {
    "dev": "deno run -A npm:wrangler dev --config wrangler.local.toml",
    "dev:web": "deno run -A npm:vite --config web/vite.config.ts",
    "dev:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server.ts",
    "build": "deno run -A npm:vite build --config web/vite.config.ts",
    "build:worker": "deno run -A npm:esbuild src/backend/index.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser --target=es2022 --conditions=workerd,worker,browser --external:cloudflare:* --external:node:*",
    "build:takos-worker": "deno run -A scripts/build-takos-worker.ts",
    "takos:migrate": "deno run -A scripts/apply-takos-migrations.ts",
    "deploy": "deno task build && deno run -A npm:wrangler deploy --config wrangler.toml",
    "check": "deno check src/**/*.ts web/src/**/*.ts web/src/**/*.tsx web/public.ts web/vite.config.ts",
    "test": "deno test --allow-all src/ web/src/ test/",
    "lint": "deno lint src/ web/src/",
    "fmt": "deno fmt src/ web/src/",
    "fmt:check": "deno fmt --check src/ web/src/",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:push": "deno run -A npm:drizzle-kit push",
    "db:migrate": "deno run -A npm:drizzle-kit migrate",
    "db:studio": "deno run -A npm:drizzle-kit studio"
  }
}
