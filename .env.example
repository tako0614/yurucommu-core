# =============================================================================
# Yurucommu - Environment Variables
# =============================================================================
# This file documents common local/runtime environment variables used by yurucommu.
# Copy this file to .dev.vars for local development with wrangler.
#
# For Cloudflare Workers deployment:
# - Set via wrangler.toml [vars] for non-sensitive config
# - Set via `wrangler secret put <NAME>` for secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration (wrangler.toml [vars])
# -----------------------------------------------------------------------------
APP_URL=https://app.yurucommu.com

# CSRF allowed origins (comma-separated). APP_URL の origin に加えて受け付ける
# 追加 origin。 未設定なら APP_URL のみ accept (= production-equivalent strict
# mode で backward compat)。
#
# dev で hostname-based access する場合 (= takosumi local-substrate
# yurucommu.test reverse proxy 経由)、 dev hostname をここに register:
#   CSRF_ALLOWED_ORIGINS=https://yurucommu.test
#
# 詳細は takos-private/docs/operations/lan-dev-setup.md を参照。
# CSRF_ALLOWED_ORIGINS=

# Local Deno server port. Defaults to 3000.
PORT=3000

# Takos Platform URL (for OAuth and API integration, set explicitly when enabled)
TAKOS_URL=https://takos.example.com

# Takos integration feature flags fail closed unless explicitly enabled.
ENABLE_TAKOS_PROXY=false
ENABLE_TAKOS_TOOLS=false

# -----------------------------------------------------------------------------
# Authentication - Password (Optional)
# Set via: wrangler secret put AUTH_PASSWORD_HASH
# PBKDF2-SHA256 password hash for single-user instances.
# Format: saltHex:hashHex
# -----------------------------------------------------------------------------
AUTH_PASSWORD_HASH=0123456789abcdef0123456789abcdef:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# -----------------------------------------------------------------------------
# Authentication - Google OAuth (Optional)
# Set via: wrangler secret put GOOGLE_CLIENT_ID
#          wrangler secret put GOOGLE_CLIENT_SECRET
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Authentication - X/Twitter OAuth (Optional)
# Set via: wrangler secret put X_CLIENT_ID
#          wrangler secret put X_CLIENT_SECRET
# -----------------------------------------------------------------------------
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# -----------------------------------------------------------------------------
# Authentication - Takosumi Accounts OIDC (Optional)
# Set via: wrangler secret put TAKOSUMI_ACCOUNTS_CLIENT_ID
#          wrangler secret put TAKOSUMI_ACCOUNTS_CLIENT_SECRET
# Enables Takosumi Accounts login for this app installation.
# -----------------------------------------------------------------------------
TAKOSUMI_ACCOUNTS_ISSUER_URL=https://accounts.example.com
TAKOSUMI_ACCOUNTS_CLIENT_ID=your-accounts-client-id
TAKOSUMI_ACCOUNTS_CLIENT_SECRET=your-accounts-client-secret

# -----------------------------------------------------------------------------
# Session and Token Encryption (Required for persisted auth tokens)
# Set via: wrangler secret put ENCRYPTION_KEY
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-64-character-hex-encryption-key

# -----------------------------------------------------------------------------
# Federation delivery shadow probes (Optional, staging-oriented)
# DELIVERY_SHADOW_PROBE_HOSTS is a comma-separated host allowlist.
# DELIVERY_SHADOW_PROBE_SAMPLE_RATE is 0.0-1.0 and defaults to 1.0 when hosts are set.
# -----------------------------------------------------------------------------
# DELIVERY_SHADOW_PROBE_HOSTS=example.social,remote.example
# DELIVERY_SHADOW_PROBE_SAMPLE_RATE=1.0

# =============================================================================
# Database Configuration
# =============================================================================
# Local Deno runtime uses SQLite at DATABASE_PATH.
# This is read by `deno task dev:deno` and `deno task start`.
DATABASE_PATH=./data/yurucommu.db

# Optional local Deno runtime paths:
# STORAGE_PATH=./data/storage
# ASSETS_PATH=./dist
# MIGRATIONS_PATH=./migrations

# Production and `wrangler dev` use Cloudflare D1 via the DB binding.
# Configure it in wrangler.toml under [[d1_databases]], not with an env var.

# =============================================================================
# Cloudflare Bindings (Configured in wrangler.toml, not here)
# =============================================================================
# The following are configured as bindings in wrangler.toml:
#
# D1 Database:
#   binding = "DB"
#   database_name = "yurucommu-db"
#
# R2 Bucket (for media storage):
#   binding = "MEDIA"
#   bucket_name = "yurucommu-media"
#
# KV Namespace (for sessions, OAuth state):
#   binding = "KV"
#   id = "<your-kv-namespace-id>"  # Create with: wrangler kv:namespace create
#
# Static Assets:
#   binding = "ASSETS"
#
# Cloudflare Queues (for federation delivery and DLQ):
#   binding = "DELIVERY_QUEUE"
#   queue = "yurucommu-delivery"
#   binding = "DELIVERY_DLQ"
#   queue = "yurucommu-delivery-dlq"
# =============================================================================
