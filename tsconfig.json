{
  "extends": "../takos/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["@cloudflare/workers-types", "node"],
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "web/**/*.ts", "web/**/*.tsx"]
}
