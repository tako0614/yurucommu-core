{
  "name": "@takos/yurucommu",
  "version": "2.0.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "exports": {
    ".": "./src/backend/public.ts",
    "./server": "./src/backend/public.ts",
    "./web": "./web/public.ts",
    "./plugins": "./src/plugin/public.ts"
  },
  "imports": {
    "#test/assert": "./shims/std/assert.ts",
    "#test/mock": "./shims/std/mock.ts",
    "#test/time": "./shims/std/time.ts"
  },
  "scripts": {
    "start": "bun src/backend/server.ts",
    "dev": "bunx wrangler dev --config wrangler.local.toml",
    "dev:web": "bunx vite --config web/vite.config.ts",
    "dev:server": "bun src/backend/server.ts",
    "check": "tsc --noEmit",
    "test": "bun test test/ src/backend/ web/",
    "test:backend": "bun test src/backend/",
    "build": "bunx vite build --config web/vite.config.ts",
    "build:worker": "bun x esbuild src/backend/index.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser --target=es2022 --conditions=workerd,worker,browser --external:cloudflare:* --external:node:*",
    "build:takos-worker": "bun scripts/build-takos-worker.ts",
    "app:migrate": "bun scripts/apply-takos-migrations.ts",
    "takos:migrate": "bun scripts/apply-takos-migrations.ts",
    "deploy": "bun run build && bunx wrangler deploy --config wrangler.toml",
    "lint": "bun run check",
    "fmt": "bunx prettier --write src web test site",
    "fmt:check": "bunx prettier --check src web test site",
    "db:generate": "bunx drizzle-kit generate",
    "db:push": "bunx drizzle-kit push",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@libsql/client": "^0.17.0",
    "@solidjs/router": "^0.15.0",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.45.1",
    "fdir": "^6.5.0",
    "hono": "^4.12.9",
    "html5-qrcode": "^2.3.8",
    "jotai": "^2.18.0",
    "merge-anything": "^5.1.7",
    "picomatch": "^4.0.4",
    "qrcode-generator": "^2.0.4",
    "solid-jotai": "^0.3.0",
    "solid-js": "^1.9.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@cloudflare/workers-types": "^4.20260420.1",
    "@tailwindcss/node": "^4.1.18",
    "@tailwindcss/oxide": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "babel-preset-solid": "^1.9.12",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.12",
    "rollup": "^4.60.2",
    "solid-refresh": "^0.6.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.0",
    "vitefu": "^1.1.3",
    "wrangler": "^4.103.0"
  }
}
