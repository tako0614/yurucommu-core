{
  "name": "@takos/yurucommu",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./src/server.ts",
  "types": "./src/server.ts",
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./web": {
      "types": "./src/web.ts",
      "import": "./src/web.ts"
    },
    "./web/styles.css": "./src/frontend/src/styles.css",
    "./plugins": {
      "types": "./src/plugins.ts",
      "import": "./src/plugins.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite --config src/vite.config.ts",
    "dev:node": "tsx watch src/server-node.ts",
    "dev:bun": "bun run src/server-bun.ts",
    "dev:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/server-deno.ts",
    "start:node": "tsx src/server-node.ts",
    "start:bun": "bun run src/server-bun.ts",
    "start:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/server-deno.ts",
    "start:workerd": "wrangler dev --local",
    "build": "vite build --config src/vite.config.ts",
    "build:worker": "esbuild src/server-app.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser --target=es2022 --conditions=workerd,worker,browser --external:cloudflare:* --external:node:*",
    "build:bundle": "npm run build && npm run build:worker",
    "deploy": "vite build --config src/vite.config.ts && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hono/node-server": "^1.13.0",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-d1": "^7.3.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.4",
    "html5-qrcode": "^2.3.8",
    "prisma": "^7.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.12.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260118.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.61.0"
  }
}