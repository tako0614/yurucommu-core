{
  "name": "@takos/yurucommu",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/backend/public.ts",
  "types": "./src/backend/public.ts",
  "exports": {
    ".": {
      "types": "./src/backend/public.ts",
      "import": "./src/backend/public.ts"
    },
    "./server": {
      "types": "./src/backend/public.ts",
      "import": "./src/backend/public.ts"
    },
    "./web": {
      "types": "./web/public.ts",
      "import": "./web/public.ts"
    },
    "./web/styles.css": "./web/styles.css",
    "./plugins": {
      "types": "./src/plugin/public.ts",
      "import": "./src/plugin/public.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:node": "tsx watch src/backend/server.ts",
    "dev:bun": "bun run src/backend/server-bun.ts",
    "dev:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server-deno.ts",
    "start:node": "tsx src/backend/server.ts",
    "start:bun": "bun run src/backend/server-bun.ts",
    "start:deno": "deno run --allow-net --allow-read --allow-write --allow-env src/backend/server-deno.ts",
    "start:workerd": "wrangler dev --local",
    "build": "vite build --config web/vite.config.ts",
    "build:worker": "esbuild src/backend/index.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser --target=es2022 --conditions=workerd,worker,browser --external:cloudflare:* --external:node:*",
    "build:bundle": "npm run build && npm run build:worker",
    "deploy": "vite build --config web/vite.config.ts && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ web/src/",
    "lint:fix": "eslint src/ web/src/ --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:d1:apply:local": "wrangler d1 migrations apply DB --local --config wrangler.local.toml",
    "db:d1:apply:remote": "wrangler d1 migrations apply DB --remote",
    "db:d1:apply:tenant2": "wrangler d1 migrations apply DB --remote --config wrangler.tenant2.toml",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'web/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'web/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hono/node-server": "^1.13.0",
    "@libsql/client": "^0.17.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.4",
    "html5-qrcode": "^2.3.8",
    "jotai": "^2.18.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.12.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260118.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.12",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.1",
    "wrangler": "^4.61.0"
  }
}
