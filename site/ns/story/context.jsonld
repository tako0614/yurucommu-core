{
  "@context": {
    "story": "https://yurucommu.com/ns/story#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Story": "story:Story",

    "displayDuration": {
      "@id": "story:displayDuration",
      "@type": "xsd:duration"
    },

    "overlays": {
      "@id": "story:overlays",
      "@container": "@list"
    },
    "position": "story:position",
    "replyPolicy": "story:replyPolicy",
    "reactionPolicy": "story:reactionPolicy"
  }
}
